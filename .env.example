# Copy to .env and fill in values.

# Groq API key for chat completions (https://console.groq.com/)
GROQ_API_KEY=gsk_...

# Streamlit UI → FastAPI (optional; default http://127.0.0.1:8000)
# RAG_API_BASE=http://127.0.0.1:8000

# Optional: absolute path to the data folder (defaults to <repo>/data)
# DATA_DIR=/full/path/to/AI-powered-language-learning-chatbot-inspired-by-Duolingo/data

# Optional overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
# TOP_K_RETRIEVAL=5

# Chat transcript log (append-only JSON Lines under data/)
# CHAT_LOG_ENABLED=true
# CHAT_LOG_PATH=chat_log.jsonl
